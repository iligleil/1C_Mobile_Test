#Область ОбработчикиСобытий

Процедура ПередУдалением(Отказ)

	Если ОбменДанными.Загрузка Тогда
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	// Проверяем, было ли заполнено имя файла
	Если ЗначениеЗаполнено(ИмяФайлаВыгрузки) Тогда

		ПутьКЗагрузкам = "/storage/emulated/0/Download/Inventory_ERP/";
		ПолныйПуть = ПутьКЗагрузкам + ИмяФайлаВыгрузки;

		ФайлНаДиске = Новый Файл(ПолныйПуть);
		Если ФайлНаДиске.Существует() Тогда
			Попытка
				УдалитьФайлы(ПолныйПуть);
			Исключение
				// Если файл занят или нет прав, просто пишем в лог, 
				// чтобы не прерывать удаление самого документа
				Сообщить("Не удалось удалить файл: " + ИмяФайлаВыгрузки);
			КонецПопытки;
		КонецЕсли;

	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти