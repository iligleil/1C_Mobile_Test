#Область ОбработчикиСобытий

&НаКлиенте
Процедура ОбработкаКоманды(ПараметрКоманды, ПараметрыВыполненияКоманды)
	
	// 1. Подготовка пути
	// В Android путь к публичным загрузкам обычно такой:
	ПутьКЗагрузкам = "/storage/emulated/0/Download/Inventory_ERP/";
	

	// 2. Вызываем серверную процедуру для формирования и записи файлов
	// Выполняем запись файлов в контексте сервера мобильного приложения
	КоличествоФайлов = ЗаписатьДокументыВФайлыНаСервере(ПутьКЗагрузкам);

	Если КоличествоФайлов.Количество() > 0 Тогда
		ПоказатьОповещениеПользователя("Готово", , "Файлы сохранены в Download/Inventory_ERP/");
	Иначе
		ПоказатьОповещениеПользователя("Внимание", , "Нет проведенных документов для выгрузки");
	КонецЕсли;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаСервере
Функция ЗаписатьДокументыВФайлыНаСервере(ПутьКЗагрузкам)

	МассивПутей = Новый Массив;
	
	// Создаем каталог, если его нет (на сервере в мобилке это работает)
	ФайлДиректория = Новый Файл(ПутьКЗагрузкам);
	Если Не ФайлДиректория.Существует() Тогда
		СоздатьКаталог(ПутьКЗагрузкам);
	КонецЕсли;

	// Получаем данные (запрос внутри функции)
	ДанныеДляЭкспорта = ПолучитьМассивДокументовДляВыгрузки();

	Для Каждого ДанныеДока Из ДанныеДляЭкспорта Цикл

		ИмяФайла = "document_" + ДанныеДока.ID + ".json";
		ПолныйПуть = ПутьКЗагрузкам + ИмяФайла;
		
		// Формируем структуру JSON
		СтруктураJSON = Новый Структура;
		СтруктураJSON.Вставить("name", "Документ " + ДанныеДока.ID);
		СтруктураJSON.Вставить("updatedAt", Формат(ТекущаяДата(), "ДФ=yyyy-MM-ddTHH:mm:ss"));

		МассивСтрок = Новый Массив;
		Для Каждого СтрокаТЧ Из ДанныеДока.Строки Цикл

			ТекстFullContent = "{""GUID"":""" + СтрокаТЧ.GUID 
							+ """,""ORG"":""" + СтрокаТЧ.ORG 
							+ """,""NAME"":""" + СтрокаТЧ.NAME
							+ """}";

			Стр = Новый Структура("fullContent, displayTitle, quantity");
			Стр.fullContent  = ТекстFullContent;
			Стр.displayTitle = СтрокаТЧ.NAME;
			Стр.quantity     = СтрокаТЧ.COUNT;
			МассивСтрок.Добавить(Стр);

		КонецЦикла;

		СтруктураJSON.Вставить("items", МассивСтрок);

		// Запись через ТекстовыйДокумент (на сервере доступен!)
		ЗаписьJSON = Новый ЗаписьJSON;
		ЗаписьJSON.УстановитьСтроку(Новый ПараметрыЗаписиJSON(ПереносСтрокJSON.Авто, "  "));
		ЗаписатьJSON(ЗаписьJSON, СтруктураJSON);
		СтрокаJSON = ЗаписьJSON.Закрыть();

		ЗаписьТекста = Новый ЗаписьТекста;

		Попытка
			ЗаписьТекста.Открыть(ПолныйПуть, КодировкаТекста.UTF8);
			ЗаписьТекста.Записать(СтрокаJSON);
			ЗаписьТекста.Закрыть();

			МассивПутей.Добавить(ПолныйПуть);
		Исключение
			ТекстОшибки = "Ошибка записи файла " + ИмяФайла + ": " + ОписаниеОшибки();
			Сообщить(ТекстОшибки);
		КонецПопытки;

	КонецЦикла;

	Возврат МассивПутей;

КонецФункции

&НаСервере
Функция ПолучитьМассивДокументовДляВыгрузки()
	
	// Здесь мы группируем данные по документам
	// Возвращаем массив структур, где в каждой структуре есть ID документа и массив его строк
	Запрос = Новый Запрос("ВЫБРАТЬ
						  |	СборДанных.Ссылка КАК Ссылка,
						  |	СборДанных.Номер КАК Номер,
						  |	СборДанныхРезультатСчитывания.Наименование КАК NAME,
						  |	СборДанныхРезультатСчитывания.Количество КАК COUNT,
						  |	СборДанныхРезультатСчитывания.Организация КАК ORG,
						  |	СборДанныхРезультатСчитывания.Гуид КАК GUID
						  |ИЗ
						  |	Документ.СборДанных КАК СборДанных
						  |		ВНУТРЕННЕЕ СОЕДИНЕНИЕ Документ.СборДанных.РезультатСчитывания КАК СборДанныхРезультатСчитывания
						  |		ПО СборДанных.Ссылка = СборДанныхРезультатСчитывания.Ссылка
						  |ГДЕ
						  |	СборДанных.Проведен = ИСТИНА
						  |ИТОГИ
						  |ПО
						  |	Ссылка");

	Результат = Новый Массив;
	ВыборкаДок = Запрос.Выполнить().Выбрать(ОбходРезультатаЗапроса.ПоГруппировкам);

	Пока ВыборкаДок.Следующий() Цикл

		ДанныеДока = Новый Структура("ID, Строки");
		ДанныеДока.ID = СтрЗаменить(ВыборкаДок.Номер, " ", "_");

		МассивСтрок = Новый Массив;
		ВыборкаСтрок = ВыборкаДок.Выбрать();
		Пока ВыборкаСтрок.Следующий() Цикл
			СтрТЧ = Новый Структура("NAME, COUNT, ORG, GUID");
			ЗаполнитьЗначенияСвойств(СтрТЧ, ВыборкаСтрок);
			МассивСтрок.Добавить(СтрТЧ);
		КонецЦикла;

		ДанныеДока.Строки = МассивСтрок;
		Результат.Добавить(ДанныеДока);

	КонецЦикла;

	Возврат Результат;

КонецФункции

#КонецОбласти